<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <TextView
        android:id="@+id/nn_ze_tv_analytics_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Analytics"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/nn_ze_tv_income_result"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Income: —"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"
        app:layout_constraintTop_toBottomOf="@id/nn_ze_tv_analytics_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/nn_ze_tv_expenses_result"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Expenses: —"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"
        app:layout_constraintTop_toBottomOf="@id/nn_ze_tv_income_result"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/nn_ze_tv_savings_result"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Final Savings: —"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/nn_ze_tv_expenses_result"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>